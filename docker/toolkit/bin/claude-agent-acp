#!/bin/sh
TOOLKIT="${MEMOH_TOOLKIT_DIR:-/opt/memoh/toolkit}"
CLAUDE_AGENT_ACP="$TOOLKIT/acp/lib/node_modules/@agentclientprotocol/claude-agent-acp/dist/index.js"
TOOLKIT_CA_BUNDLE="$TOOLKIT/certs/ca-certificates.crt"

if [ -z "${SSL_CERT_FILE:-}" ] && [ -f "$TOOLKIT_CA_BUNDLE" ]; then
  export SSL_CERT_FILE="$TOOLKIT_CA_BUNDLE"
fi

fallback_claude_agent_acp() {
  old_ifs="$IFS"
  IFS=:
  for dir in $PATH; do
    IFS="$old_ifs"
    [ -n "$dir" ] || dir=.
    case "$dir" in
      "$TOOLKIT/bin") ;;
      *)
        if [ -x "$dir/claude-agent-acp" ]; then
          exec "$dir/claude-agent-acp" "$@"
        fi
        ;;
    esac
    IFS=:
  done
  IFS="$old_ifs"
}

if [ ! -f "$CLAUDE_AGENT_ACP" ]; then
  fallback_claude_agent_acp "$@"
  echo "claude-agent-acp is not installed in the Memoh workspace toolkit and no fallback claude-agent-acp command was found: $CLAUDE_AGENT_ACP" >&2
  exit 127
fi

case "$(uname -m)" in
  x86_64)  GLIBC_LOADER=/lib64/ld-linux-x86-64.so.2 ;;
  aarch64|arm64) GLIBC_LOADER=/lib/ld-linux-aarch64.so.1 ;;
  *) GLIBC_LOADER= ;;
esac
if ls /lib/ld-musl-*.so.1 >/dev/null 2>&1 && { [ -z "$GLIBC_LOADER" ] || [ ! -e "$GLIBC_LOADER" ]; }; then
  fallback_claude_agent_acp "$@"
  echo "claude-agent-acp requires a glibc workspace image. Use the default Debian workspace image for Claude Code ACP sessions." >&2
  exit 127
fi
if [ -d "$TOOLKIT/glibc-lib" ]; then
  export LD_LIBRARY_PATH="$TOOLKIT/glibc-lib${LD_LIBRARY_PATH:+:$LD_LIBRARY_PATH}"
fi
exec "$TOOLKIT/bin/node" "$CLAUDE_AGENT_ACP" "$@"
